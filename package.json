{
	"name": "reo-agent",
	"version": "0.1.2",
	"type": "module",
	"description": "AI-powered terminal coding assistant",
	"author": "Mohamed Reda Chakir",
	"keywords": ["ai", "cli", "agent", "typescript"],
	"bin": {
		"reo": "./src/main.tsx"
	},
	"scripts": {
		"dev": "bun run src/main.tsx",
		"build": "bun build src/main.tsx --outdir dist --target bun",
		"build:prod": "bun build src/main.tsx --outdir dist --target bun --minify",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"test": "bun test"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.91.0",
		"@commander-js/extra-typings": "^12.1.0",
		"@google/generative-ai": "^0.24.1",
		"@modelcontextprotocol/sdk": "^1.0.0",
		"chalk": "^5.4.0",
		"chokidar": "^4.0.0",
		"commander": "^12.1.0",
		"diff": "^7.0.0",
		"execa": "^9.5.0",
		"fuse.js": "^7.0.0",
		"glob": "^13.0.6",
		"ink": "^5.1.0",
		"marked": "^15.0.0",
		"openai": "^6.34.0",
		"ora": "^9.4.0",
		"react": "^19.0.0",
		"react-devtools-core": "^7.0.1",
		"react-reconciler": "^0.31.0",
		"yaml": "^2.6.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"@types/diff": "^6.0.0",
		"@types/node": "^22.0.0",
		"typescript": "^5.7.0",
		"@biomejs/biome": "^1.9.0",
		"bun-types": "^1.1.0"
	}
}
